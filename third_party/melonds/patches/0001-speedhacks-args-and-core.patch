+/// Arguments that configure aggressive speedhacks.
+/// These intentionally prioritize speed over correctness.
+struct SpeedhackArgs
+{
+    bool SpeedFirst = false;
+
+    /// If enabled, allows subsystems to use cheaper timing / batching.
+    bool CoarseTiming = false;
+
+    /// If enabled, allows 3D rendering shortcuts / approximations.
+    bool Fast3D = false;
+
+    /// If enabled, allows cheaper audio mixing / resampling.
+    bool FastAudio = false;
+};
+
 /// Arguments to pass into the NDS constructor.
 /// New fields here should have default values if possible.
 struct NDSArgs
@@ -128,6 +144,10 @@ struct NDSArgs
     /// Defaults to the software renderer.
     /// Can be changed later at any time.
     std::unique_ptr<melonDS::Renderer3D> Renderer3D = std::make_unique<SoftRenderer>();
+
+    /// Speedhacks configuration.
+    /// Defaults to disabled.
+    SpeedhackArgs Speedhacks {};
 };
 
